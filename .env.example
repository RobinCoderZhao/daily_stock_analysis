# ===================================
# SaaS Multi-Tenant Configuration
# ===================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# === SaaS Mode ===
SAAS_MODE=true
DATABASE_PATH=./data/saas_test.db
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# === Server ===
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8018
ADMIN_AUTH_ENABLED=true
CORS_ORIGINS=https://devkit-suite.com
AGENT_MODE=true

# ===================================
# AI / LLM Configuration
# ===================================
# Gemini API Key (required for stock analysis)
GEMINI_API_KEY=
# Multi-key rotation (comma-separated, optional)
LLM_GEMINI_API_KEYS=

# Primary analysis model (LiteLLM format: provider/model)
# Default: gemini/gemini-3-flash-preview
LITELLM_MODEL=gemini/gemini-3-flash-preview
# Fallback models (comma-separated)
LITELLM_FALLBACK_MODELS=gemini/gemini-2.5-flash

# Legacy Gemini config (used when LITELLM_MODEL is not set)
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_REQUEST_DELAY=2.0
GEMINI_MAX_RETRIES=5

# Other AI providers (optional)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# Brave Search API (for market sentiment)
BRAVE_API_KEYS=

# ===================================
# Stock Analysis
# ===================================
STOCK_LIST=600519,300750,002594
TUSHARE_TOKEN=

# ===================================
# Data Source Priority
# ===================================
# Historical data priority (lower = higher priority)
# EFINANCE_PRIORITY=0
# AKSHARE_PRIORITY=1
# TUSHARE_PRIORITY=2
# PYTDX_PRIORITY=2
# BAOSTOCK_PRIORITY=3
# YFINANCE_PRIORITY=4

# Real-time quote source priority (comma-separated)
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
ENABLE_REALTIME_QUOTE=true
ENABLE_REALTIME_TECHNICAL_INDICATORS=true
# ENABLE_CHIP_DISTRIBUTION=true
# ENABLE_EASTMONEY_PATCH=false

# ===================================
# Scheduled Tasks
# ===================================
SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00
RUN_IMMEDIATELY=true
MARKET_REVIEW_ENABLED=true
MARKET_REVIEW_REGION=both

# ===================================
# Backtesting
# ===================================
BACKTEST_ENABLED=true
BACKTEST_EVAL_WINDOW_DAYS=10
BACKTEST_MIN_AGE_DAYS=14
BACKTEST_ENGINE_VERSION=v1
BACKTEST_NEUTRAL_BAND_PCT=2.0

# ===================================
# Report Configuration
# ===================================
# SINGLE_STOCK_NOTIFY=false
# REPORT_TYPE=simple
# REPORT_SUMMARY_ONLY=false
# ANALYSIS_DELAY=0

# ===================================
# Notification Channels (all optional)
# ===================================
# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# WeChat Work
# WECHAT_WEBHOOK=

# DingTalk
# DINGTALK_WEBHOOK=
# DINGTALK_SECRET=
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
# DINGTALK_STREAM_ENABLED=false

# Feishu
# FEISHU_WEBHOOK=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_STREAM_ENABLED=false

# Email
# EMAIL_HOST=
# EMAIL_PORT=465
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_TO=

# Server Chan
# SERVERCHAN_KEY=
# SERVERCHAN3_SENDKEY=

# Custom Webhook
# CUSTOM_NOTIFY_URL=

# Markdown to Image (for channels without markdown support)
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000
# MD2IMG_ENGINE=wkhtmltoimage

# ===================================
# System / Logging
# ===================================
LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false

# ===================================
# Proxy (optional, for local dev)
# ===================================
# USE_PROXY=false
# PROXY_HOST=127.0.0.1
# PROXY_PORT=10809
